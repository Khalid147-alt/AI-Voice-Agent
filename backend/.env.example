# Leave VAPI keys blank to run in DEMO MODE (full UI + seed data, no real calls).
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_PHONE_NUMBER_ID=

# Optional: enables real LLM post-call analysis via LangGraph (Gemini 2.5 Flash).
GOOGLE_API_KEY=your_gemini_api_key_from_aistudio_google_com
ELEVENLABS_API_KEY=

DATABASE_URL=sqlite+aiosqlite:///./voicedesk.db
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
