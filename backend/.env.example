# ── Required ──────────────────────────────────────────────────
# VAPI (https://dashboard.vapi.ai). The private key powers the backend;
# the public key is used by the browser Web SDK for in-browser test calls.
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_PUBLIC_KEY=your_vapi_public_key

# Google Gemini (https://aistudio.google.com) — powers the LangGraph
# post-call analysis pipeline (gemini-2.5-flash).
GOOGLE_API_KEY=your_gemini_api_key

# ── Required for outbound PHONE calls & campaigns ────────────────
# Import/buy a number in the VAPI dashboard, then paste its Phone Number ID.
# Leave blank if you only use in-browser web calls (no number needed).
VAPI_PHONE_NUMBER_ID=

# ── Voice ────────────────────────────────────────────────────────
# ElevenLabs (https://elevenlabs.io) — register this key in your VAPI org
# (Providers → Voice) so the live assistant can speak with ElevenLabs voices.
ELEVENLABS_API_KEY=

# ── App ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./voicedesk.db
# IMPORTANT: set to your PUBLIC/deployed backend URL so VAPI can deliver
# webhooks (transcripts, end-of-call reports). localhost is NOT reachable
# by VAPI's servers — use ngrok for local testing or your deploy URL in prod.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
