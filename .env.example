# ─────────────────────────────────────────────────────────────
# VoiceDesk environment configuration
# Copy this file to backend/.env (and frontend/.env.local for the
# NEXT_PUBLIC_* vars). Leave VAPI keys blank to run in DEMO MODE.
# ─────────────────────────────────────────────────────────────

# VAPI (https://dashboard.vapi.ai) — leave blank for demo mode
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=
VAPI_PHONE_NUMBER_ID=

# Google Gemini — used by the LangGraph post-call analysis pipeline (gemini-2.5-flash).
# Optional: without it, analysis falls back to a heuristic / mock.
GOOGLE_API_KEY=your_gemini_api_key_from_aistudio_google_com

# ElevenLabs — voice synthesis (configured per-agent in VAPI)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# App
DATABASE_URL=sqlite+aiosqlite:///./voicedesk.db
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Frontend (put these in frontend/.env.local) ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

