# ─────────────────────────────────────────────────────────────
# VoiceDesk environment configuration
# Copy this file to backend/.env, and set the NEXT_PUBLIC_* vars in
# frontend/.env.local. All keys below are required for full functionality.
# ─────────────────────────────────────────────────────────────

# VAPI (https://dashboard.vapi.ai)
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_PUBLIC_KEY=your_vapi_public_key
# Required only for outbound PHONE calls & campaigns. Import a number in the
# VAPI dashboard and paste its Phone Number ID. Web calls don't need this.
VAPI_PHONE_NUMBER_ID=

# Google Gemini (https://aistudio.google.com) — LangGraph post-call analysis.
GOOGLE_API_KEY=your_gemini_api_key

# ElevenLabs — register this key in your VAPI org (Providers → Voice) so the
# live assistant can speak with ElevenLabs voices.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# App
DATABASE_URL=sqlite+aiosqlite:///./voicedesk.db
# Set to your PUBLIC/deployed backend URL so VAPI can deliver webhooks.
# localhost is NOT reachable by VAPI — use ngrok locally or your deploy URL.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ─── Frontend (put these in frontend/.env.local) ───
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key
